# ──────────────────────────────────────────────────────────────────────
# Adversarial Evidence Engine — Environment Configuration
# ──────────────────────────────────────────────────────────────────────
# Copy this file to .env and configure your settings.
# All values have sensible defaults. Change LLM_PROVIDER to switch providers.

# ──────────────────────────────────────────────────────────────────────
# LLM Provider (switch by changing this single value)
# ──────────────────────────────────────────────────────────────────────
# Options: ollama | openai | openrouter | gemini
LLM_PROVIDER=ollama

# ──────────────────────────────────────────────────────────────────────
# Ollama (local, free — requires Ollama running)
# Install: https://ollama.com/download
# ──────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ──────────────────────────────────────────────────────────────────────
# OpenAI (requires API key)
# ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4

# ──────────────────────────────────────────────────────────────────────
# OpenRouter (400+ models, some free — requires API key)
# Get key: https://openrouter.ai/settings/keys
# ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_SITE_URL=https://github.com/your-username/agon
OPENROUTER_APP_NAME=Adversarial Evidence Engine

# ──────────────────────────────────────────────────────────────────────
# Google Gemini (generous free tier — requires API key)
# Get key: https://aistudio.google.com/apikey
# ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=...
GEMINI_MODEL=gemini-2.0-flash

# ──────────────────────────────────────────────────────────────────────
# Shared LLM Config
# ──────────────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# ──────────────────────────────────────────────────────────────────────
# Vector Store
# ──────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=adversarial_evidence

# ──────────────────────────────────────────────────────────────────────
# Pipeline
# ──────────────────────────────────────────────────────────────────────
NLI_MODEL=cross-encoder/nli-deberta-v3-base
TOP_K_RETRIEVAL=10
TOP_K_SUPPORT=4
TOP_K_CONTRADICT=4
TOP_K_NUANCE=2

# ──────────────────────────────────────────────────────────────────────
# Data Ingestion (all free, no API keys)
# ──────────────────────────────────────────────────────────────────────
ARXIV_MAX_RESULTS=20
SEMANTIC_SCHOLAR_LIMIT=20
WEB_SEARCH_MAX_RESULTS=10
RSS_FEED_TIMEOUT=10

# ──────────────────────────────────────────────────────────────────────
# API
# ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT_PER_MINUTE=20
LOG_LEVEL=INFO

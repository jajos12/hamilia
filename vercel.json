{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/api/main.py": {
      "runtime": "python3.11",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "src/api/main.py"
    },
    {
      "source": "/health",
      "destination": "src/api/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs"
}